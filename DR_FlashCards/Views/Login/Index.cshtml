@*
*@
@{
    ViewData["Title"] = "Login Page";
}
<h1>Login</h1>
<form asp-controller="Login" asp-action="Login" method="post">
    <div>
        <label for="email">Email:</label>
        <input type="email"
               id="email"
               name="email"
               required />
    </div>

    <div>
        <label for="password">Password:</label>
        <input type="password"
               id="password"
               name="password"
               required />
    </div>

    <div>
        <button type="submit">
            Entrar
        </button>
    </div>
</form>
